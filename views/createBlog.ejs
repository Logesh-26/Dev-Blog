<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/css/bootstrap') %>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>blogs</title>
</head>

<body>
    <%- include('./partials/components/nav') %>
    <div class="container">
        <div class="my-5">
            <h1>Create new Blog</h1>
        </div>
        <form enctype="multipart/form-data" class="form" method="POST" action="/blog/create">

            <div class="mb-3">
                <label for="coverImage" class="form-label">Cover Image</label>
                <input type="file" 
                name="coverImage"
                />
            </div>
            <div class="mb-3">
                <label 
                for="title" 
                class="form-label"
                >
                Title
            </label>
                <input 
                name="title" 
                type="text" 
                class="form-control" 
                id="title" 
                aria-describedby="title"
                />
            </div>
            <div class="mb-3">
                <label
                for="content"
                class="form-label"
            >Content</label>
            <textarea 
            class="form-control"
            name="content"
            id="content"
            ></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Create</button>
        </form>
    </div>
        <%- include('./partials/js/bootstrap') %>
</body>

</html>